<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.canglian.business.mapper.WmsInventoryCheckMapper">

    <resultMap type="WmsInventoryCheck" id="WmsInventoryCheckResult">
        <id     property="checkId"          column="check_id"          />
        <result property="checkNo"          column="check_no"          />
        <result property="warehouseId"      column="warehouse_id"      />
        <result property="status"           column="status"            />
        <result property="totalDiffQty"     column="total_diff_qty"    />
        <result property="totalDiffAmount"  column="total_diff_amount" />
        <result property="createBy"         column="create_by"         />
        <result property="createTime"       column="create_time"       />
        <result property="updateBy"         column="update_by"         />
        <result property="updateTime"       column="update_time"       />
        <result property="remark"           column="remark"            />
    </resultMap>

    <sql id="selectWmsInventoryCheckVo">
        select check_id, check_no, warehouse_id, status, total_diff_qty, total_diff_amount,
               create_by, create_time, update_by, update_time, remark
        from wms_inventory_check
    </sql>

    <select id="selectWmsInventoryCheckById" parameterType="Long" resultMap="WmsInventoryCheckResult">
        <include refid="selectWmsInventoryCheckVo"/>
        where check_id = #{checkId}
    </select>

    <select id="selectWmsInventoryCheckList" parameterType="WmsInventoryCheck" resultMap="WmsInventoryCheckResult">
        <include refid="selectWmsInventoryCheckVo"/>
        <where>
            <if test="checkNo != null and checkNo != ''">
                and check_no like concat('%', #{checkNo}, '%')
            </if>
            <if test="warehouseId != null">
                and warehouse_id = #{warehouseId}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
    </select>

    <select id="selectMaxCheckNoByPrefix" parameterType="String" resultType="String">
        select max(check_no)
        from wms_inventory_check
        where check_no like concat(#{checkNoPrefix}, '%')
    </select>

    <insert id="insertWmsInventoryCheck" parameterType="WmsInventoryCheck" useGeneratedKeys="true" keyProperty="checkId">
        insert into wms_inventory_check
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="checkNo != null and checkNo != ''">check_no,</if>
            <if test="warehouseId != null">warehouse_id,</if>
            <if test="status != null">status,</if>
            <if test="totalDiffQty != null">total_diff_qty,</if>
            <if test="totalDiffAmount != null">total_diff_amount,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            <if test="updateBy != null and updateBy != ''">update_by,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="checkNo != null and checkNo != ''">#{checkNo},</if>
            <if test="warehouseId != null">#{warehouseId},</if>
            <if test="status != null">#{status},</if>
            <if test="totalDiffQty != null">#{totalDiffQty},</if>
            <if test="totalDiffAmount != null">#{totalDiffAmount},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
            <if test="updateBy != null and updateBy != ''">#{updateBy},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateWmsInventoryCheck" parameterType="WmsInventoryCheck">
        update wms_inventory_check
        <set>
            <if test="checkNo != null and checkNo != ''">check_no = #{checkNo},</if>
            <if test="warehouseId != null">warehouse_id = #{warehouseId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="totalDiffQty != null">total_diff_qty = #{totalDiffQty},</if>
            <if test="totalDiffAmount != null">total_diff_amount = #{totalDiffAmount},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where check_id = #{checkId}
    </update>

    <delete id="deleteWmsInventoryCheckById" parameterType="Long">
        delete from wms_inventory_check where check_id = #{checkId}
    </delete>

    <delete id="deleteWmsInventoryCheckByIds" parameterType="Long">
        delete from wms_inventory_check where check_id in
        <foreach collection="array" item="checkId" open="(" separator="," close=")">
            #{checkId}
        </foreach>
    </delete>
</mapper>

