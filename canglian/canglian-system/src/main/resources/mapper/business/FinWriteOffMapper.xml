<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.canglian.business.mapper.FinWriteOffMapper">

    <resultMap type="FinWriteOff" id="FinWriteOffResult">
        <id     property="writeOffId"    column="write_off_id"    />
        <result property="writeOffNo"    column="write_off_no"    />
        <result property="writeOffType"  column="write_off_type"  />
        <result property="receivableId"  column="receivable_id"   />
        <result property="payableId"     column="payable_id"      />
        <result property="receiptId"     column="receipt_id"      />
        <result property="paymentId"     column="payment_id"      />
        <result property="amount"        column="amount"          />
        <result property="writeOffDate"  column="write_off_date"  />
        <result property="status"        column="status"          />
        <result property="createBy"      column="create_by"       />
        <result property="createTime"    column="create_time"     />
        <result property="updateBy"      column="update_by"       />
        <result property="updateTime"    column="update_time"     />
        <result property="remark"        column="remark"          />
    </resultMap>

    <sql id="selectFinWriteOffVo">
        select write_off_id, write_off_no, write_off_type, receivable_id, payable_id, receipt_id, payment_id,
               amount, write_off_date, status, create_by, create_time, update_by, update_time, remark
        from fin_write_off
    </sql>

    <select id="selectFinWriteOffById" parameterType="Long" resultMap="FinWriteOffResult">
        <include refid="selectFinWriteOffVo"/>
        where write_off_id = #{writeOffId}
    </select>

    <select id="selectFinWriteOffList" parameterType="FinWriteOff" resultMap="FinWriteOffResult">
        <include refid="selectFinWriteOffVo"/>
        <where>
            <if test="writeOffNo != null and writeOffNo != ''">
                and write_off_no like concat('%', #{writeOffNo}, '%')
            </if>
            <if test="writeOffType != null and writeOffType != ''">
                and write_off_type = #{writeOffType}
            </if>
            <if test="receivableId != null">
                and receivable_id = #{receivableId}
            </if>
            <if test="payableId != null">
                and payable_id = #{payableId}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
    </select>

    <insert id="insertFinWriteOff" parameterType="FinWriteOff" useGeneratedKeys="true" keyProperty="writeOffId">
        insert into fin_write_off
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="writeOffNo != null and writeOffNo != ''">write_off_no,</if>
            <if test="writeOffType != null and writeOffType != ''">write_off_type,</if>
            <if test="receivableId != null">receivable_id,</if>
            <if test="payableId != null">payable_id,</if>
            <if test="receiptId != null">receipt_id,</if>
            <if test="paymentId != null">payment_id,</if>
            <if test="amount != null">amount,</if>
            <if test="writeOffDate != null">write_off_date,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            <if test="updateBy != null and updateBy != ''">update_by,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="writeOffNo != null and writeOffNo != ''">#{writeOffNo},</if>
            <if test="writeOffType != null and writeOffType != ''">#{writeOffType},</if>
            <if test="receivableId != null">#{receivableId},</if>
            <if test="payableId != null">#{payableId},</if>
            <if test="receiptId != null">#{receiptId},</if>
            <if test="paymentId != null">#{paymentId},</if>
            <if test="amount != null">#{amount},</if>
            <if test="writeOffDate != null">#{writeOffDate},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
            <if test="updateBy != null and updateBy != ''">#{updateBy},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateFinWriteOff" parameterType="FinWriteOff">
        update fin_write_off
        <set>
            <if test="writeOffNo != null and writeOffNo != ''">write_off_no = #{writeOffNo},</if>
            <if test="writeOffType != null and writeOffType != ''">write_off_type = #{writeOffType},</if>
            <if test="receivableId != null">receivable_id = #{receivableId},</if>
            <if test="payableId != null">payable_id = #{payableId},</if>
            <if test="receiptId != null">receipt_id = #{receiptId},</if>
            <if test="paymentId != null">payment_id = #{paymentId},</if>
            <if test="amount != null">amount = #{amount},</if>
            <if test="writeOffDate != null">write_off_date = #{writeOffDate},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where write_off_id = #{writeOffId}
    </update>

    <delete id="deleteFinWriteOffById" parameterType="Long">
        delete from fin_write_off where write_off_id = #{writeOffId}
    </delete>

    <delete id="deleteFinWriteOffByIds" parameterType="Long">
        delete from fin_write_off where write_off_id in
        <foreach collection="array" item="writeOffId" open="(" separator="," close=")">
            #{writeOffId}
        </foreach>
    </delete>
</mapper>

