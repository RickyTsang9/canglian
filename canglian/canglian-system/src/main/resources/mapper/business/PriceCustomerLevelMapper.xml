<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.canglian.business.mapper.PriceCustomerLevelMapper">

    <resultMap type="PriceCustomerLevel" id="PriceCustomerLevelResult">
        <id property="levelPriceId" column="level_price_id" />
        <result property="customerLevel" column="customer_level" />
        <result property="productId" column="product_id" />
        <result property="salePrice" column="sale_price" />
        <result property="status" column="status" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectPriceCustomerLevelVo">
        select level_price_id, customer_level, product_id, sale_price, status, create_by, create_time, update_by, update_time, remark
        from price_customer_level
    </sql>

    <select id="selectPriceCustomerLevelById" parameterType="Long" resultMap="PriceCustomerLevelResult">
        <include refid="selectPriceCustomerLevelVo"/>
        where level_price_id = #{levelPriceId}
    </select>

    <select id="selectPriceCustomerLevelList" parameterType="PriceCustomerLevel" resultMap="PriceCustomerLevelResult">
        <include refid="selectPriceCustomerLevelVo"/>
        <where>
            <if test="customerLevel != null and customerLevel != ''">
                and customer_level = #{customerLevel}
            </if>
            <if test="productId != null">
                and product_id = #{productId}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by update_time desc, create_time desc
    </select>

    <insert id="insertPriceCustomerLevel" parameterType="PriceCustomerLevel" useGeneratedKeys="true" keyProperty="levelPriceId">
        insert into price_customer_level
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="customerLevel != null and customerLevel != ''">customer_level,</if>
            <if test="productId != null">product_id,</if>
            <if test="salePrice != null">sale_price,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            <if test="updateBy != null and updateBy != ''">update_by,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="customerLevel != null and customerLevel != ''">#{customerLevel},</if>
            <if test="productId != null">#{productId},</if>
            <if test="salePrice != null">#{salePrice},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
            <if test="updateBy != null and updateBy != ''">#{updateBy},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updatePriceCustomerLevel" parameterType="PriceCustomerLevel">
        update price_customer_level
        <set>
            <if test="customerLevel != null and customerLevel != ''">customer_level = #{customerLevel},</if>
            <if test="productId != null">product_id = #{productId},</if>
            <if test="salePrice != null">sale_price = #{salePrice},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where level_price_id = #{levelPriceId}
    </update>

    <delete id="deletePriceCustomerLevelById" parameterType="Long">
        delete from price_customer_level where level_price_id = #{levelPriceId}
    </delete>

    <delete id="deletePriceCustomerLevelByIds" parameterType="Long">
        delete from price_customer_level where level_price_id in
        <foreach collection="array" item="levelPriceId" open="(" separator="," close=")">
            #{levelPriceId}
        </foreach>
    </delete>
</mapper>
