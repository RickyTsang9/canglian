<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.canglian.business.mapper.FinBadDebtMapper">

    <resultMap type="FinBadDebt" id="FinBadDebtResult">
        <id     property="badDebtId"   column="bad_debt_id"   />
        <result property="badDebtNo"   column="bad_debt_no"   />
        <result property="receivableId" column="receivable_id" />
        <result property="customerId"  column="customer_id"   />
        <result property="amount"      column="amount"        />
        <result property="badDebtDate" column="bad_debt_date" />
        <result property="reason"      column="reason"        />
        <result property="status"      column="status"        />
        <result property="createBy"    column="create_by"     />
        <result property="createTime"  column="create_time"   />
        <result property="updateBy"    column="update_by"     />
        <result property="updateTime"  column="update_time"   />
        <result property="remark"      column="remark"        />
    </resultMap>

    <sql id="selectFinBadDebtVo">
        select bad_debt_id, bad_debt_no, receivable_id, customer_id, amount, bad_debt_date, reason,
               status, create_by, create_time, update_by, update_time, remark
        from fin_bad_debt
    </sql>

    <select id="selectFinBadDebtById" parameterType="Long" resultMap="FinBadDebtResult">
        <include refid="selectFinBadDebtVo"/>
        where bad_debt_id = #{badDebtId}
    </select>

    <select id="selectFinBadDebtList" parameterType="FinBadDebt" resultMap="FinBadDebtResult">
        <include refid="selectFinBadDebtVo"/>
        <where>
            <if test="badDebtNo != null and badDebtNo != ''">
                and bad_debt_no like concat('%', #{badDebtNo}, '%')
            </if>
            <if test="receivableId != null">
                and receivable_id = #{receivableId}
            </if>
            <if test="customerId != null">
                and customer_id = #{customerId}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
    </select>

    <insert id="insertFinBadDebt" parameterType="FinBadDebt" useGeneratedKeys="true" keyProperty="badDebtId">
        insert into fin_bad_debt
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="badDebtNo != null and badDebtNo != ''">bad_debt_no,</if>
            <if test="receivableId != null">receivable_id,</if>
            <if test="customerId != null">customer_id,</if>
            <if test="amount != null">amount,</if>
            <if test="badDebtDate != null">bad_debt_date,</if>
            <if test="reason != null and reason != ''">reason,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            <if test="updateBy != null and updateBy != ''">update_by,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="badDebtNo != null and badDebtNo != ''">#{badDebtNo},</if>
            <if test="receivableId != null">#{receivableId},</if>
            <if test="customerId != null">#{customerId},</if>
            <if test="amount != null">#{amount},</if>
            <if test="badDebtDate != null">#{badDebtDate},</if>
            <if test="reason != null and reason != ''">#{reason},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
            <if test="updateBy != null and updateBy != ''">#{updateBy},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateFinBadDebt" parameterType="FinBadDebt">
        update fin_bad_debt
        <set>
            <if test="badDebtNo != null and badDebtNo != ''">bad_debt_no = #{badDebtNo},</if>
            <if test="receivableId != null">receivable_id = #{receivableId},</if>
            <if test="customerId != null">customer_id = #{customerId},</if>
            <if test="amount != null">amount = #{amount},</if>
            <if test="badDebtDate != null">bad_debt_date = #{badDebtDate},</if>
            <if test="reason != null and reason != ''">reason = #{reason},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where bad_debt_id = #{badDebtId}
    </update>

    <delete id="deleteFinBadDebtById" parameterType="Long">
        delete from fin_bad_debt where bad_debt_id = #{badDebtId}
    </delete>

    <delete id="deleteFinBadDebtByIds" parameterType="Long">
        delete from fin_bad_debt where bad_debt_id in
        <foreach collection="array" item="badDebtId" open="(" separator="," close=")">
            #{badDebtId}
        </foreach>
    </delete>
</mapper>

