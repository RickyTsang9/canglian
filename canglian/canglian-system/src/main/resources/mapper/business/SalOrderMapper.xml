<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.canglian.business.mapper.SalOrderMapper">

    <resultMap type="SalOrder" id="SalOrderResult">
        <id property="orderId" column="order_id" />
        <result property="orderNo" column="order_no" />
        <result property="orderType" column="order_type" />
        <result property="customerId" column="customer_id" />
        <result property="warehouseId" column="warehouse_id" />
        <result property="sourceBillType" column="source_bill_type" />
        <result property="sourceBillId" column="source_bill_id" />
        <result property="sourceBillNo" column="source_bill_no" />
        <result property="businessDate" column="business_date" />
        <result property="expectedDate" column="expected_date" />
        <result property="totalQty" column="total_qty" />
        <result property="totalAmount" column="total_amount" />
        <result property="status" column="status" />
        <result property="bizStatus" column="biz_status" />
        <result property="approveBy" column="approve_by" />
        <result property="approveTime" column="approve_time" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectSalOrderVo">
        select order_id, order_no, order_type, customer_id, warehouse_id, source_bill_type, source_bill_id, source_bill_no,
               business_date, expected_date, total_qty, total_amount, status, biz_status, approve_by, approve_time,
               create_by, create_time, update_by, update_time, remark
        from sal_order
    </sql>

    <select id="selectSalOrderById" parameterType="Long" resultMap="SalOrderResult">
        <include refid="selectSalOrderVo"/>
        where order_id = #{orderId}
    </select>

    <select id="selectSalOrderList" parameterType="SalOrder" resultMap="SalOrderResult">
        <include refid="selectSalOrderVo"/>
        <where>
            <if test="orderNo != null and orderNo != ''">
                and order_no like concat('%', #{orderNo}, '%')
            </if>
            <if test="orderType != null and orderType != ''">
                and order_type = #{orderType}
            </if>
            <if test="customerId != null">
                and customer_id = #{customerId}
            </if>
            <if test="warehouseId != null">
                and warehouse_id = #{warehouseId}
            </if>
            <if test="sourceBillNo != null and sourceBillNo != ''">
                and source_bill_no like concat('%', #{sourceBillNo}, '%')
            </if>
            <if test="bizStatus != null and bizStatus != ''">
                and biz_status = #{bizStatus}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <insert id="insertSalOrder" parameterType="SalOrder" useGeneratedKeys="true" keyProperty="orderId">
        insert into sal_order
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">order_no,</if>
            <if test="orderType != null">order_type,</if>
            <if test="customerId != null">customer_id,</if>
            <if test="warehouseId != null">warehouse_id,</if>
            <if test="sourceBillType != null">source_bill_type,</if>
            <if test="sourceBillId != null">source_bill_id,</if>
            <if test="sourceBillNo != null and sourceBillNo != ''">source_bill_no,</if>
            <if test="businessDate != null">business_date,</if>
            <if test="expectedDate != null">expected_date,</if>
            <if test="totalQty != null">total_qty,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="status != null">status,</if>
            <if test="bizStatus != null">biz_status,</if>
            <if test="approveBy != null">approve_by,</if>
            <if test="approveTime != null">approve_time,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            <if test="updateBy != null and updateBy != ''">update_by,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">#{orderNo},</if>
            <if test="orderType != null">#{orderType},</if>
            <if test="customerId != null">#{customerId},</if>
            <if test="warehouseId != null">#{warehouseId},</if>
            <if test="sourceBillType != null">#{sourceBillType},</if>
            <if test="sourceBillId != null">#{sourceBillId},</if>
            <if test="sourceBillNo != null and sourceBillNo != ''">#{sourceBillNo},</if>
            <if test="businessDate != null">#{businessDate},</if>
            <if test="expectedDate != null">#{expectedDate},</if>
            <if test="totalQty != null">#{totalQty},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="status != null">#{status},</if>
            <if test="bizStatus != null">#{bizStatus},</if>
            <if test="approveBy != null">#{approveBy},</if>
            <if test="approveTime != null">#{approveTime},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
            <if test="updateBy != null and updateBy != ''">#{updateBy},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateSalOrder" parameterType="SalOrder">
        update sal_order
        <set>
            <if test="orderNo != null and orderNo != ''">order_no = #{orderNo},</if>
            <if test="orderType != null">order_type = #{orderType},</if>
            <if test="customerId != null">customer_id = #{customerId},</if>
            <if test="warehouseId != null">warehouse_id = #{warehouseId},</if>
            <if test="sourceBillType != null">source_bill_type = #{sourceBillType},</if>
            <if test="sourceBillId != null">source_bill_id = #{sourceBillId},</if>
            <if test="sourceBillNo != null and sourceBillNo != ''">source_bill_no = #{sourceBillNo},</if>
            <if test="businessDate != null">business_date = #{businessDate},</if>
            <if test="expectedDate != null">expected_date = #{expectedDate},</if>
            <if test="totalQty != null">total_qty = #{totalQty},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="bizStatus != null">biz_status = #{bizStatus},</if>
            <if test="approveBy != null">approve_by = #{approveBy},</if>
            <if test="approveTime != null">approve_time = #{approveTime},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where order_id = #{orderId}
    </update>

    <delete id="deleteSalOrderById" parameterType="Long">
        delete from sal_order where order_id = #{orderId}
    </delete>

    <delete id="deleteSalOrderByIds" parameterType="Long">
        delete from sal_order where order_id in
        <foreach collection="array" item="orderId" open="(" separator="," close=")">
            #{orderId}
        </foreach>
    </delete>

    <select id="selectMaxOrderNoByPrefix" parameterType="String" resultType="String">
        select max(order_no) from sal_order where order_no like concat(#{orderNoPrefix}, '%')
    </select>
</mapper>
