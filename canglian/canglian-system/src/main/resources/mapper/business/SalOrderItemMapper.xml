<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.canglian.business.mapper.SalOrderItemMapper">

    <resultMap type="SalOrderItem" id="SalOrderItemResult">
        <id property="orderItemId" column="order_item_id" />
        <result property="orderId" column="order_id" />
        <result property="productId" column="product_id" />
        <result property="quantity" column="quantity" />
        <result property="price" column="price" />
        <result property="amount" column="amount" />
        <result property="remark" column="remark" />
    </resultMap>

    <select id="selectSalOrderItemListByOrderId" parameterType="Long" resultMap="SalOrderItemResult">
        select order_item_id, order_id, product_id, quantity, price, amount, remark
        from sal_order_item
        where order_id = #{orderId}
        order by order_item_id asc
    </select>

    <insert id="insertSalOrderItem" parameterType="SalOrderItem" useGeneratedKeys="true" keyProperty="orderItemId">
        insert into sal_order_item(order_id, product_id, quantity, price, amount, remark)
        values(#{orderId}, #{productId}, #{quantity}, #{price}, #{amount}, #{remark})
    </insert>

    <delete id="deleteSalOrderItemByOrderId" parameterType="Long">
        delete from sal_order_item where order_id = #{orderId}
    </delete>
</mapper>
