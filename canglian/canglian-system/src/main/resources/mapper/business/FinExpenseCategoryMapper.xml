<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.canglian.business.mapper.FinExpenseCategoryMapper">

    <resultMap type="FinExpenseCategory" id="FinExpenseCategoryResult">
        <id     property="categoryId"   column="category_id" />
        <result property="parentId"     column="parent_id" />
        <result property="ancestors"    column="ancestors" />
        <result property="categoryName" column="category_name" />
        <result property="categoryCode" column="category_code" />
        <result property="orderNum"     column="order_num" />
        <result property="status"       column="status" />
        <result property="delFlag"      column="del_flag" />
        <result property="parentName"   column="parent_name" />
        <result property="createBy"     column="create_by" />
        <result property="createTime"   column="create_time" />
        <result property="updateBy"     column="update_by" />
        <result property="updateTime"   column="update_time" />
        <result property="remark"       column="remark" />
    </resultMap>

    <sql id="selectFinExpenseCategoryVo">
        select category_id, parent_id, ancestors, category_name, category_code, order_num, status, del_flag,
               create_by, create_time, update_by, update_time, remark
        from fin_expense_category
    </sql>

    <select id="selectFinExpenseCategoryById" parameterType="Long" resultMap="FinExpenseCategoryResult">
        select category_id, parent_id, ancestors, category_name, category_code, order_num, status, del_flag,
               (select category_name from fin_expense_category where category_id = expense_category.parent_id) parent_name,
               create_by, create_time, update_by, update_time, remark
        from fin_expense_category expense_category
        where category_id = #{categoryId}
    </select>

    <select id="selectFinExpenseCategoryList" parameterType="FinExpenseCategory" resultMap="FinExpenseCategoryResult">
        <include refid="selectFinExpenseCategoryVo"/>
        where del_flag = '0'
        <if test="categoryId != null and categoryId != 0">
            and category_id = #{categoryId}
        </if>
        <if test="parentId != null and parentId != 0">
            and parent_id = #{parentId}
        </if>
        <if test="categoryName != null and categoryName != ''">
            and category_name like concat('%', #{categoryName}, '%')
        </if>
        <if test="categoryCode != null and categoryCode != ''">
            and category_code = #{categoryCode}
        </if>
        <if test="status != null and status != ''">
            and status = #{status}
        </if>
        order by parent_id, order_num
    </select>

    <select id="selectChildrenExpenseCategoryById" parameterType="Long" resultMap="FinExpenseCategoryResult">
        select * from fin_expense_category where find_in_set(#{categoryId}, ancestors)
    </select>

    <select id="hasChildByCategoryId" parameterType="Long" resultType="int">
        select count(1) from fin_expense_category
        where del_flag = '0' and parent_id = #{categoryId} limit 1
    </select>

    <select id="checkCategoryNameUnique" resultMap="FinExpenseCategoryResult">
        <include refid="selectFinExpenseCategoryVo"/>
        where category_name = #{categoryName} and parent_id = #{parentId} and del_flag = '0' limit 1
    </select>

    <insert id="insertFinExpenseCategory" parameterType="FinExpenseCategory" useGeneratedKeys="true" keyProperty="categoryId">
        insert into fin_expense_category(
            <if test="parentId != null and parentId != 0">parent_id,</if>
            <if test="ancestors != null and ancestors != ''">ancestors,</if>
            <if test="categoryName != null and categoryName != ''">category_name,</if>
            <if test="categoryCode != null and categoryCode != ''">category_code,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        ) values (
            <if test="parentId != null and parentId != 0">#{parentId},</if>
            <if test="ancestors != null and ancestors != ''">#{ancestors},</if>
            <if test="categoryName != null and categoryName != ''">#{categoryName},</if>
            <if test="categoryCode != null and categoryCode != ''">#{categoryCode},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <update id="updateFinExpenseCategory" parameterType="FinExpenseCategory">
        update fin_expense_category
        <set>
            <if test="parentId != null and parentId != 0">parent_id = #{parentId},</if>
            <if test="ancestors != null and ancestors != ''">ancestors = #{ancestors},</if>
            <if test="categoryName != null and categoryName != ''">category_name = #{categoryName},</if>
            <if test="categoryCode != null and categoryCode != ''">category_code = #{categoryCode},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where category_id = #{categoryId}
    </update>

    <update id="updateExpenseCategoryChildren" parameterType="java.util.List">
        update fin_expense_category set ancestors =
        <foreach collection="expenseCategories" item="item" index="index"
            separator=" " open="case category_id" close="end">
            when #{item.categoryId} then #{item.ancestors}
        </foreach>
        where category_id in
        <foreach collection="expenseCategories" item="item" index="index"
            separator="," open="(" close=")">
            #{item.categoryId}
        </foreach>
    </update>

    <delete id="deleteFinExpenseCategoryById" parameterType="Long">
        update fin_expense_category set del_flag = '2' where category_id = #{categoryId}
    </delete>

    <delete id="deleteFinExpenseCategoryByIds" parameterType="Long">
        update fin_expense_category set del_flag = '2' where category_id in
        <foreach collection="array" item="categoryId" open="(" separator="," close=")">
            #{categoryId}
        </foreach>
    </delete>
</mapper>

