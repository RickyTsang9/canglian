<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.canglian.business.mapper.FinVoucherEventMapper">

    <resultMap type="FinVoucherEvent" id="FinVoucherEventResult">
        <id property="voucherEventId" column="voucher_event_id" />
        <result property="billType" column="bill_type" />
        <result property="billId" column="bill_id" />
        <result property="billNo" column="bill_no" />
        <result property="eventType" column="event_type" />
        <result property="eventDate" column="event_date" />
        <result property="eventAmount" column="event_amount" />
        <result property="status" column="status" />
        <result property="voucherNo" column="voucher_no" />
        <result property="voucherStatus" column="voucher_status" />
        <result property="voucherDate" column="voucher_date" />
        <result property="generatedBy" column="generated_by" />
        <result property="generatedTime" column="generated_time" />
        <result property="writebackStatus" column="writeback_status" />
        <result property="writebackMessage" column="writeback_message" />
        <result property="reverseVoucherNo" column="reverse_voucher_no" />
        <result property="reversedBy" column="reversed_by" />
        <result property="reversedTime" column="reversed_time" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectFinVoucherEventVo">
        select voucher_event_id, bill_type, bill_id, bill_no, event_type, event_date, event_amount, status,
               voucher_no, voucher_status, voucher_date, generated_by, generated_time, writeback_status,
               writeback_message, reverse_voucher_no, reversed_by, reversed_time,
               create_by, create_time, update_by, update_time, remark
        from fin_voucher_event
    </sql>

    <select id="selectFinVoucherEventById" parameterType="Long" resultMap="FinVoucherEventResult">
        <include refid="selectFinVoucherEventVo"/>
        where voucher_event_id = #{voucherEventId}
    </select>

    <select id="selectFinVoucherEventList" parameterType="FinVoucherEvent" resultMap="FinVoucherEventResult">
        <include refid="selectFinVoucherEventVo"/>
        <where>
            <if test="billType != null and billType != ''">
                and bill_type = #{billType}
            </if>
            <if test="billNo != null and billNo != ''">
                and bill_no like concat('%', #{billNo}, '%')
            </if>
            <if test="eventType != null and eventType != ''">
                and event_type = #{eventType}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <insert id="insertFinVoucherEvent" parameterType="FinVoucherEvent" useGeneratedKeys="true" keyProperty="voucherEventId">
        insert into fin_voucher_event
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="billType != null">bill_type,</if>
            <if test="billId != null">bill_id,</if>
            <if test="billNo != null">bill_no,</if>
            <if test="eventType != null">event_type,</if>
            <if test="eventDate != null">event_date,</if>
            <if test="eventAmount != null">event_amount,</if>
            <if test="status != null">status,</if>
            <if test="voucherNo != null and voucherNo != ''">voucher_no,</if>
            <if test="voucherStatus != null and voucherStatus != ''">voucher_status,</if>
            <if test="voucherDate != null">voucher_date,</if>
            <if test="generatedBy != null and generatedBy != ''">generated_by,</if>
            <if test="generatedTime != null">generated_time,</if>
            <if test="writebackStatus != null and writebackStatus != ''">writeback_status,</if>
            <if test="writebackMessage != null and writebackMessage != ''">writeback_message,</if>
            <if test="reverseVoucherNo != null and reverseVoucherNo != ''">reverse_voucher_no,</if>
            <if test="reversedBy != null and reversedBy != ''">reversed_by,</if>
            <if test="reversedTime != null">reversed_time,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            <if test="updateBy != null and updateBy != ''">update_by,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="billType != null">#{billType},</if>
            <if test="billId != null">#{billId},</if>
            <if test="billNo != null">#{billNo},</if>
            <if test="eventType != null">#{eventType},</if>
            <if test="eventDate != null">#{eventDate},</if>
            <if test="eventAmount != null">#{eventAmount},</if>
            <if test="status != null">#{status},</if>
            <if test="voucherNo != null and voucherNo != ''">#{voucherNo},</if>
            <if test="voucherStatus != null and voucherStatus != ''">#{voucherStatus},</if>
            <if test="voucherDate != null">#{voucherDate},</if>
            <if test="generatedBy != null and generatedBy != ''">#{generatedBy},</if>
            <if test="generatedTime != null">#{generatedTime},</if>
            <if test="writebackStatus != null and writebackStatus != ''">#{writebackStatus},</if>
            <if test="writebackMessage != null and writebackMessage != ''">#{writebackMessage},</if>
            <if test="reverseVoucherNo != null and reverseVoucherNo != ''">#{reverseVoucherNo},</if>
            <if test="reversedBy != null and reversedBy != ''">#{reversedBy},</if>
            <if test="reversedTime != null">#{reversedTime},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
            <if test="updateBy != null and updateBy != ''">#{updateBy},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateFinVoucherEvent" parameterType="FinVoucherEvent">
        update fin_voucher_event
        <set>
            <if test="billType != null">bill_type = #{billType},</if>
            <if test="billId != null">bill_id = #{billId},</if>
            <if test="billNo != null">bill_no = #{billNo},</if>
            <if test="eventType != null">event_type = #{eventType},</if>
            <if test="eventDate != null">event_date = #{eventDate},</if>
            <if test="eventAmount != null">event_amount = #{eventAmount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="voucherNo != null and voucherNo != ''">voucher_no = #{voucherNo},</if>
            <if test="voucherStatus != null and voucherStatus != ''">voucher_status = #{voucherStatus},</if>
            <if test="voucherDate != null">voucher_date = #{voucherDate},</if>
            <if test="generatedBy != null and generatedBy != ''">generated_by = #{generatedBy},</if>
            <if test="generatedTime != null">generated_time = #{generatedTime},</if>
            <if test="writebackStatus != null and writebackStatus != ''">writeback_status = #{writebackStatus},</if>
            <if test="writebackMessage != null and writebackMessage != ''">writeback_message = #{writebackMessage},</if>
            <if test="reverseVoucherNo != null and reverseVoucherNo != ''">reverse_voucher_no = #{reverseVoucherNo},</if>
            <if test="reversedBy != null and reversedBy != ''">reversed_by = #{reversedBy},</if>
            <if test="reversedTime != null">reversed_time = #{reversedTime},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where voucher_event_id = #{voucherEventId}
    </update>

    <delete id="deleteFinVoucherEventById" parameterType="Long">
        delete from fin_voucher_event where voucher_event_id = #{voucherEventId}
    </delete>

    <delete id="deleteFinVoucherEventByIds" parameterType="Long">
        delete from fin_voucher_event where voucher_event_id in
        <foreach collection="array" item="voucherEventId" open="(" separator="," close=")">
            #{voucherEventId}
        </foreach>
    </delete>

    <select id="selectMaxVoucherNoByPrefix" parameterType="String" resultType="String">
        select max(voucher_no) from fin_voucher_event where voucher_no like concat(#{voucherNoPrefix}, '%')
    </select>
</mapper>
