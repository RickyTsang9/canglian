<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.canglian.business.mapper.FinVoucherEventMapper">

    <resultMap type="FinVoucherEvent" id="FinVoucherEventResult">
        <id property="voucherEventId" column="voucher_event_id" />
        <result property="billType" column="bill_type" />
        <result property="billId" column="bill_id" />
        <result property="billNo" column="bill_no" />
        <result property="eventType" column="event_type" />
        <result property="eventDate" column="event_date" />
        <result property="eventAmount" column="event_amount" />
        <result property="status" column="status" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectFinVoucherEventVo">
        select voucher_event_id, bill_type, bill_id, bill_no, event_type, event_date, event_amount, status,
               create_by, create_time, update_by, update_time, remark
        from fin_voucher_event
    </sql>

    <select id="selectFinVoucherEventById" parameterType="Long" resultMap="FinVoucherEventResult">
        <include refid="selectFinVoucherEventVo"/>
        where voucher_event_id = #{voucherEventId}
    </select>

    <select id="selectFinVoucherEventList" parameterType="FinVoucherEvent" resultMap="FinVoucherEventResult">
        <include refid="selectFinVoucherEventVo"/>
        <where>
            <if test="billType != null and billType != ''">
                and bill_type = #{billType}
            </if>
            <if test="billNo != null and billNo != ''">
                and bill_no like concat('%', #{billNo}, '%')
            </if>
            <if test="eventType != null and eventType != ''">
                and event_type = #{eventType}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <insert id="insertFinVoucherEvent" parameterType="FinVoucherEvent" useGeneratedKeys="true" keyProperty="voucherEventId">
        insert into fin_voucher_event
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="billType != null">bill_type,</if>
            <if test="billId != null">bill_id,</if>
            <if test="billNo != null">bill_no,</if>
            <if test="eventType != null">event_type,</if>
            <if test="eventDate != null">event_date,</if>
            <if test="eventAmount != null">event_amount,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            <if test="updateBy != null and updateBy != ''">update_by,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="billType != null">#{billType},</if>
            <if test="billId != null">#{billId},</if>
            <if test="billNo != null">#{billNo},</if>
            <if test="eventType != null">#{eventType},</if>
            <if test="eventDate != null">#{eventDate},</if>
            <if test="eventAmount != null">#{eventAmount},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
            <if test="updateBy != null and updateBy != ''">#{updateBy},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateFinVoucherEvent" parameterType="FinVoucherEvent">
        update fin_voucher_event
        <set>
            <if test="billType != null">bill_type = #{billType},</if>
            <if test="billId != null">bill_id = #{billId},</if>
            <if test="billNo != null">bill_no = #{billNo},</if>
            <if test="eventType != null">event_type = #{eventType},</if>
            <if test="eventDate != null">event_date = #{eventDate},</if>
            <if test="eventAmount != null">event_amount = #{eventAmount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where voucher_event_id = #{voucherEventId}
    </update>

    <delete id="deleteFinVoucherEventById" parameterType="Long">
        delete from fin_voucher_event where voucher_event_id = #{voucherEventId}
    </delete>

    <delete id="deleteFinVoucherEventByIds" parameterType="Long">
        delete from fin_voucher_event where voucher_event_id in
        <foreach collection="array" item="voucherEventId" open="(" separator="," close=")">
            #{voucherEventId}
        </foreach>
    </delete>
</mapper>
