<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.canglian.business.mapper.PriceCustomerSpecialMapper">

    <resultMap type="PriceCustomerSpecial" id="PriceCustomerSpecialResult">
        <id property="specialPriceId" column="special_price_id" />
        <result property="customerId" column="customer_id" />
        <result property="productId" column="product_id" />
        <result property="salePrice" column="sale_price" />
        <result property="status" column="status" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectPriceCustomerSpecialVo">
        select special_price_id, customer_id, product_id, sale_price, status, create_by, create_time, update_by, update_time, remark
        from price_customer_special
    </sql>

    <select id="selectPriceCustomerSpecialById" parameterType="Long" resultMap="PriceCustomerSpecialResult">
        <include refid="selectPriceCustomerSpecialVo"/>
        where special_price_id = #{specialPriceId}
    </select>

    <select id="selectPriceCustomerSpecialList" parameterType="PriceCustomerSpecial" resultMap="PriceCustomerSpecialResult">
        <include refid="selectPriceCustomerSpecialVo"/>
        <where>
            <if test="customerId != null">
                and customer_id = #{customerId}
            </if>
            <if test="productId != null">
                and product_id = #{productId}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by update_time desc, create_time desc
    </select>

    <insert id="insertPriceCustomerSpecial" parameterType="PriceCustomerSpecial" useGeneratedKeys="true" keyProperty="specialPriceId">
        insert into price_customer_special
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="customerId != null">customer_id,</if>
            <if test="productId != null">product_id,</if>
            <if test="salePrice != null">sale_price,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            <if test="updateBy != null and updateBy != ''">update_by,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="customerId != null">#{customerId},</if>
            <if test="productId != null">#{productId},</if>
            <if test="salePrice != null">#{salePrice},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
            <if test="updateBy != null and updateBy != ''">#{updateBy},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updatePriceCustomerSpecial" parameterType="PriceCustomerSpecial">
        update price_customer_special
        <set>
            <if test="customerId != null">customer_id = #{customerId},</if>
            <if test="productId != null">product_id = #{productId},</if>
            <if test="salePrice != null">sale_price = #{salePrice},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where special_price_id = #{specialPriceId}
    </update>

    <delete id="deletePriceCustomerSpecialById" parameterType="Long">
        delete from price_customer_special where special_price_id = #{specialPriceId}
    </delete>

    <delete id="deletePriceCustomerSpecialByIds" parameterType="Long">
        delete from price_customer_special where special_price_id in
        <foreach collection="array" item="specialPriceId" open="(" separator="," close=")">
            #{specialPriceId}
        </foreach>
    </delete>
</mapper>
