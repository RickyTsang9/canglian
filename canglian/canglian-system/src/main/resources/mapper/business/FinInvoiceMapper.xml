<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.canglian.business.mapper.FinInvoiceMapper">

    <resultMap type="FinInvoice" id="FinInvoiceResult">
        <id property="invoiceId" column="invoice_id" />
        <result property="invoiceNo" column="invoice_no" />
        <result property="invoiceType" column="invoice_type" />
        <result property="customerId" column="customer_id" />
        <result property="supplierId" column="supplier_id" />
        <result property="sourceBillType" column="source_bill_type" />
        <result property="sourceBillId" column="source_bill_id" />
        <result property="sourceBillNo" column="source_bill_no" />
        <result property="businessDate" column="business_date" />
        <result property="invoiceDate" column="invoice_date" />
        <result property="invoiceAmount" column="invoice_amount" />
        <result property="taxRate" column="tax_rate" />
        <result property="taxAmount" column="tax_amount" />
        <result property="untaxedAmount" column="untaxed_amount" />
        <result property="status" column="status" />
        <result property="bizStatus" column="biz_status" />
        <result property="confirmBy" column="confirm_by" />
        <result property="confirmTime" column="confirm_time" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectFinInvoiceVo">
        select invoice_id, invoice_no, invoice_type, customer_id, supplier_id, source_bill_type, source_bill_id,
               source_bill_no, business_date, invoice_date, invoice_amount, tax_rate, tax_amount, untaxed_amount,
               status, biz_status, confirm_by, confirm_time, create_by, create_time, update_by, update_time, remark
        from fin_invoice
    </sql>

    <select id="selectFinInvoiceById" parameterType="Long" resultMap="FinInvoiceResult">
        <include refid="selectFinInvoiceVo"/>
        where invoice_id = #{invoiceId}
    </select>

    <select id="selectFinInvoiceList" parameterType="FinInvoice" resultMap="FinInvoiceResult">
        <include refid="selectFinInvoiceVo"/>
        <where>
            <if test="invoiceNo != null and invoiceNo != ''">
                and invoice_no like concat('%', #{invoiceNo}, '%')
            </if>
            <if test="invoiceType != null and invoiceType != ''">
                and invoice_type = #{invoiceType}
            </if>
            <if test="customerId != null">
                and customer_id = #{customerId}
            </if>
            <if test="supplierId != null">
                and supplier_id = #{supplierId}
            </if>
            <if test="sourceBillNo != null and sourceBillNo != ''">
                and source_bill_no like concat('%', #{sourceBillNo}, '%')
            </if>
            <if test="bizStatus != null and bizStatus != ''">
                and biz_status = #{bizStatus}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by create_time desc
    </select>

    <insert id="insertFinInvoice" parameterType="FinInvoice" useGeneratedKeys="true" keyProperty="invoiceId">
        insert into fin_invoice
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="invoiceNo != null and invoiceNo != ''">invoice_no,</if>
            <if test="invoiceType != null">invoice_type,</if>
            <if test="customerId != null">customer_id,</if>
            <if test="supplierId != null">supplier_id,</if>
            <if test="sourceBillType != null">source_bill_type,</if>
            <if test="sourceBillId != null">source_bill_id,</if>
            <if test="sourceBillNo != null and sourceBillNo != ''">source_bill_no,</if>
            <if test="businessDate != null">business_date,</if>
            <if test="invoiceDate != null">invoice_date,</if>
            <if test="invoiceAmount != null">invoice_amount,</if>
            <if test="taxRate != null">tax_rate,</if>
            <if test="taxAmount != null">tax_amount,</if>
            <if test="untaxedAmount != null">untaxed_amount,</if>
            <if test="status != null">status,</if>
            <if test="bizStatus != null">biz_status,</if>
            <if test="confirmBy != null">confirm_by,</if>
            <if test="confirmTime != null">confirm_time,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            <if test="updateBy != null and updateBy != ''">update_by,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="invoiceNo != null and invoiceNo != ''">#{invoiceNo},</if>
            <if test="invoiceType != null">#{invoiceType},</if>
            <if test="customerId != null">#{customerId},</if>
            <if test="supplierId != null">#{supplierId},</if>
            <if test="sourceBillType != null">#{sourceBillType},</if>
            <if test="sourceBillId != null">#{sourceBillId},</if>
            <if test="sourceBillNo != null and sourceBillNo != ''">#{sourceBillNo},</if>
            <if test="businessDate != null">#{businessDate},</if>
            <if test="invoiceDate != null">#{invoiceDate},</if>
            <if test="invoiceAmount != null">#{invoiceAmount},</if>
            <if test="taxRate != null">#{taxRate},</if>
            <if test="taxAmount != null">#{taxAmount},</if>
            <if test="untaxedAmount != null">#{untaxedAmount},</if>
            <if test="status != null">#{status},</if>
            <if test="bizStatus != null">#{bizStatus},</if>
            <if test="confirmBy != null">#{confirmBy},</if>
            <if test="confirmTime != null">#{confirmTime},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
            <if test="updateBy != null and updateBy != ''">#{updateBy},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateFinInvoice" parameterType="FinInvoice">
        update fin_invoice
        <set>
            <if test="invoiceNo != null and invoiceNo != ''">invoice_no = #{invoiceNo},</if>
            <if test="invoiceType != null">invoice_type = #{invoiceType},</if>
            <if test="customerId != null">customer_id = #{customerId},</if>
            <if test="supplierId != null">supplier_id = #{supplierId},</if>
            <if test="sourceBillType != null">source_bill_type = #{sourceBillType},</if>
            <if test="sourceBillId != null">source_bill_id = #{sourceBillId},</if>
            <if test="sourceBillNo != null and sourceBillNo != ''">source_bill_no = #{sourceBillNo},</if>
            <if test="businessDate != null">business_date = #{businessDate},</if>
            <if test="invoiceDate != null">invoice_date = #{invoiceDate},</if>
            <if test="invoiceAmount != null">invoice_amount = #{invoiceAmount},</if>
            <if test="taxRate != null">tax_rate = #{taxRate},</if>
            <if test="taxAmount != null">tax_amount = #{taxAmount},</if>
            <if test="untaxedAmount != null">untaxed_amount = #{untaxedAmount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="bizStatus != null">biz_status = #{bizStatus},</if>
            <if test="confirmBy != null">confirm_by = #{confirmBy},</if>
            <if test="confirmTime != null">confirm_time = #{confirmTime},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where invoice_id = #{invoiceId}
    </update>

    <delete id="deleteFinInvoiceById" parameterType="Long">
        delete from fin_invoice where invoice_id = #{invoiceId}
    </delete>

    <delete id="deleteFinInvoiceByIds" parameterType="Long">
        delete from fin_invoice where invoice_id in
        <foreach collection="array" item="invoiceId" open="(" separator="," close=")">
            #{invoiceId}
        </foreach>
    </delete>

    <select id="selectMaxInvoiceNoByPrefix" parameterType="String" resultType="String">
        select max(invoice_no) from fin_invoice where invoice_no like concat(#{invoiceNoPrefix}, '%')
    </select>
</mapper>
